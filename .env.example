# ===========================================
# Kampo Ibayo Resort - Environment Variables
# ===========================================
# Copy this file to .env.local and fill in your values:
#   cp .env.example .env.local

# Application
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Supabase (https://supabase.com/dashboard)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Email (Gmail SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_gmail_app_password
SMTP_FROM=your_email@gmail.com
EMAIL_FROM=your_email@gmail.com
EMAIL_FROM_NAME=Kampo Ibayo Resort
ADMIN_EMAIL=your_admin_email@gmail.com

# SMS (SMSGate)
SMSGATE_USERNAME=your_smsgate_username
SMSGATE_PASSWORD=your_smsgate_password
SMS_ENABLED=true

# Internal API Secrets
INTERNAL_API_SECRET=generate_a_random_hex_string
CRON_SECRET=generate_a_random_hex_string
